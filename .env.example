# API Configuration
API_URL=https://api.bitbasel.miami
BASE_URL=https://app.bitbasel.miami

# Database (Neon PostgreSQL recommended on Vercel — vercel.com/integrations/neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Luma API — get key at lu.ma/developers
LUMA_API_KEY=your_luma_api_key
# Your BitBasel calendar ID (from the Luma dashboard URL: lu.ma/cal-XXXX)
LUMA_CALENDAR_ID=cal-xxxxxxxxxxxx
# Luma event API IDs for each membership tier (create recurring events in Luma)
LUMA_CREATOR_EVENT_ID=evt-xxxxxxxxxxxx
LUMA_COLLECTOR_EVENT_ID=evt-xxxxxxxxxxxx
# Luma webhook secret — generate in Luma dashboard → Webhooks → Add endpoint
# Endpoint URL: https://app.bitbasel.miami/api/luma/webhook
LUMA_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Wallet Configuration
# Get a project ID at https://cloud.walletconnect.com (required for WalletConnect QR modal)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# x402 On-Chain Payment (Collector membership, USDC on Base)
# EVM address on Base that receives the $490 USDC payment
BITBASEL_PAYMENT_ADDRESS=0xYourBaseAddress
# CDP API keys for Coinbase's mainnet-capable x402 facilitator — required for
# verify/settle on Base mainnet (eip155:8453). Create at portal.cdp.coinbase.com.
CDP_API_KEY_ID=your_cdp_api_key_id
CDP_API_KEY_SECRET=your_cdp_api_key_secret

# Bitcoin Network Configuration
BITCOIN_NETWORK=mainnet
ORDINALS_API_URL=https://ordinals.com/api

# Social Media
TWITTER_URL=https://twitter.com/bitbasel
DISCORD_URL=https://discord.gg/bitbasel
TELEGRAM_URL=https://t.me/bitbasel

# Analytics (optional)
GOOGLE_ANALYTICS_ID=
HOTJAR_ID=